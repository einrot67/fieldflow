# Database - Use Neon PostgreSQL for serverless deployment
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# NextAuth Configuration
NEXTAUTH_SECRET="generate-a-32-char-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Vapi AI Configuration (for voice features)
VAPI_API_KEY="your-vapi-api-key"
VAPI_ASSISTANT_ID="your-vapi-assistant-id"
VAPI_PHONE_NUMBER_ID="your-vapi-phone-number-id"

# Application Configuration
APP_URL="http://localhost:3000"
APP_NAME="FieldFlow"
APP_DESCRIPTION="AI-First Field Service Management"

# Stripe (for payments - optional for MVP)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_PRO="price_..."

# Email (optional for MVP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Google Maps (for route optimization - optional)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"